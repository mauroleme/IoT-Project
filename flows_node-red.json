    {
        "id": "6e33f78ddb2a3840",
        "type": "function",
        "z": "b6b0ec53c1efc6be",
        "name": "Guardar último valor",
        "func": "var d = msg.payload;\nif (d && typeof d === 'object' && d.p1_kpa !== undefined) {\n    flow.set('ultimo_valor', {\n        p1_kpa:   d.p1_kpa,\n        p2_kpa:   d.p2_kpa,\n        dp_kpa:   d.dp_kpa,\n        flow_pct: d.flow_pct,\n        estado:   d.estado,\n        ts:       new Date().toLocaleTimeString('pt-PT')\n    });\n}\nreturn msg;",
