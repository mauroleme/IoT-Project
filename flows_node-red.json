        "func": "flow.set(msg.topic === 'dp' ? 'dp_threshold' : 'q_min', msg.payload);\nvar dp = flow.get('dp_threshold') || 1.5;\nvar qm = flow.get('q_min') || 20.0;\nmsg.payload = JSON.stringify({dp_threshold: dp, q_min: qm});\nreturn msg;",
