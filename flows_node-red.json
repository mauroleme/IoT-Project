    {
        "id": "add51a76227462f7",
        "type": "function",
        "z": "b6b0ec53c1efc6be",
        "name": "Interpretar Pergunta",
        "func": "const texto = (msg.payload || '').toLowerCase().trim();\nvar d = flow.get('ultimo_valor');\n\nif (!d) {\n    msg.payload = 'Sistema não disponível no momento. Nenhum dado recebido ainda.';\n    return msg;\n}\n\nvar resposta;\n\nif (texto.includes('estado') || texto.includes('saturad')) {\n    resposta = 'O estado do filtro é ' + d.estado + '. Última leitura às ' + d.ts + '.';\n\n} else if (texto.includes('pressão') || texto.includes('pressao') || texto.includes('entrada') || texto.includes('antes') || texto.includes('saída') || texto.includes('saida')) {\n    resposta = 'A pressão antes do filtro é ' + d.p1_kpa + ' quilopascal' +\n        ', depois do filtro é ' + d.p2_kpa + ' quilopascal' +\n        ', e a pressão diferencial é ' + d.dp_kpa + ' quilopascal.';\n\n} else if (texto.includes('caudal') || texto.includes('fluxo') || texto.includes('vazão') || texto.includes('vazao')) {\n    resposta = 'O caudal está em ' + d.flow_pct + ' porcento.';\n\n} else if (\n    texto.includes('relat') ||\n    texto.includes('resumo') ||\n    texto.includes('tudo') ||\n    texto.includes('completo') ||\n    texto.includes('sensor') ||\n    texto.includes('valores') ||\n    texto.includes('dados') ||\n    texto.includes('filtro')\n) {\n    resposta = 'Filtro ' + d.estado +\n        '. Pressões ' + d.p1_kpa + ' e ' + d.p2_kpa + ' quilopascal' +\n        ', diferencial ' + d.dp_kpa +\n        '. Caudal ' + d.flow_pct + ' porcento.';\n\n} else {\n    resposta = 'Não entendi a pergunta. Pode perguntar sobre o estado do filtro, as pressões, o caudal, ou pedir um relatório completo.';\n}\n\nmsg.payload = resposta;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
