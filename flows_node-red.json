    {
        "id": "8654144f91b8787e",
        "type": "function",
        "z": "b6b0ec53c1efc6be",
        "name": "Decrypt",
        "func": "const key = Buffer.from('IPB_IoT_a52965!!', 'utf8');\nconst iv = Buffer.from('000102030405060708090A0B0C0D0E0F', 'hex');\n\ntry {\n    const encrypted = Buffer.from(msg.payload, 'base64');\n    const decipher = crypto.createDecipheriv('aes-128-cbc', key, iv);\n    decipher.setAutoPadding(true);\n    let decrypted = decipher.update(encrypted);\n    decrypted = Buffer.concat([decrypted, decipher.final()]);\n    msg.payload = JSON.parse(decrypted.toString('utf8').trim());\n    return msg;\n} catch (e) {\n    node.error(\"Erro decifração: \" + e.message);\n    return null;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
