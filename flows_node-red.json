    {
        "id": "influx_format",
        "type": "function",
        "z": "b6b0ec53c1efc6be",
        "name": "Formatar Line Protocol",
        "func": "var d = msg.payload;\n\nif (!d || typeof d !== 'object') return null;\n\nvar line = 'filtro_agua,estado=' + d.estado +\n  ' p1_kpa=' + d.p1_kpa +\n  ',p2_kpa=' + d.p2_kpa +\n  ',dp_kpa=' + d.dp_kpa +\n  ',flow_pct=' + d.flow_pct +\n  ',saturado=' + (d.saturado ? 1 : 0);\n\nmsg.payload = line;\nmsg.method = 'POST';\nmsg.url = 'http://localhost:8086/api/v2/write?org=IPB_IoT_Mauro&bucket=IoT_LAB&precision=s';\nmsg.headers = {\n  'Authorization': 'Token MRCwcjp3jOR5vYPn6tkEU4lqhkUnByZk2qAQMJOzWBCLpWuIujyPVdRWrqrmaCtFs2iadW_9dGqIZMVILtGqHQ==',\n  'Content-Type': 'text/plain'\n};\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
